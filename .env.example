# Copie ce fichier en .env.local (ignoré par git) pour le dev local.
# Sur Vercel, configure ces variables dans Project → Settings → Environment Variables.

# ============ BASE DE DONNÉES (Vercel Postgres / Neon / Supabase) ============
# Sur Vercel : créer un Postgres (onglet Storage) et cliquer "Connect to Project".
# Vercel injecte automatiquement DATABASE_URL / POSTGRES_URL / etc. Aucune action supplémentaire.
# En local : récupérer l'URL depuis Vercel → Storage → .env.local (bouton copier).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ============ AUTHENTIFICATION (NextAuth v5) ============
# Secret de signature JWT. À générer avec : `openssl rand -base64 32`
AUTH_SECRET=""

# URL publique de l'app. Auto-détectée sur Vercel, à définir en local :
# NEXTAUTH_URL="http://localhost:3000"

# ============ STRIPE (plus tard) ============
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_PRICE_ID=""
